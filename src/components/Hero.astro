---
interface Props {
	name: string;
	job: string;
	theme?: 'light' | 'dark';
}

const { name, job, theme = 'light' } = Astro.props;
---

<header class={`main-header ${theme}`} id="home">
	<div class="header-content-fixed">
		<div class="whoim">
			<div class="box-line">Who I Am</div>
		</div>
		<div class="v-content">
			<h1 class="name">{name}</h1>
			<h4 class="job"><span class="typed-text">{job}</span></h4>
		</div>
	</div>
	<slot name="nav" />
</header>

<style>
	.main-header {
		height: 100vh;
		min-height: 600px;
		position: relative;
	}

	.header-content-fixed {
		height: 100vh;
		min-height: 600px;
		background-image: url('/images/hero-mountains.jpg');
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
		background-attachment: fixed;
		text-align: center;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		position: fixed;
		top: 0;
		left: 0;
		z-index: 0;
	}

	@media (max-width: 1024px) {
		.header-content-fixed {
			position: relative;
		}
	}

	.header-content-fixed:before {
		content: "";
		position: absolute;
		width: 50%;
		left: 0;
		top: 0;
		height: 100%;
		transition: background 0.6s ease;
	}

	.header-content-fixed:after {
		content: "";
		position: absolute;
		width: 50%;
		right: 0;
		bottom: 0;
		height: 100%;
		transition: background 0.6s ease;
	}

	.main-header.light .header-content-fixed:before {
		background: rgba(255, 255, 255, 0.4);
	}
	.main-header.light .header-content-fixed:after {
		background: rgba(255, 255, 255, 0.3);
	}

	.main-header.dark .header-content-fixed:before {
		background: rgba(0, 0, 0, 0.6);
	}
	.main-header.dark .header-content-fixed:after {
		background: rgba(0, 0, 0, 0.63);
	}

	.main-header.light:hover .header-content-fixed:before {
		background: rgba(255, 255, 255, 0.9);
	}
	.main-header.light:hover .header-content-fixed:after {
		background: rgba(255, 255, 255, 0.8);
	}

	.main-header.dark:hover .header-content-fixed:before {
		background: rgba(0, 0, 0, 0.78);
	}
	.main-header.dark:hover .header-content-fixed:after {
		background: rgba(0, 0, 0, 0.8);
	}

	.whoim {
		position: absolute;
		width: 100%;
		z-index: 3;
		top: 15%;
	}

	.box-line {
		border: 3px solid #000000;
		letter-spacing: 2px;
		padding: 14px 36px;
		display: inline-block;
		text-transform: uppercase;
		font-weight: 700;
		font-size: 18px;
		background: rgba(255, 255, 255, 0.3);
	}

	.main-header.light .box-line {
		color: #000000;
		border-color: #000000;
	}

	.main-header.dark .box-line {
		color: #ffffff;
		border-color: #ffffff;
		background: transparent;
	}

	.v-content {
		position: relative;
		text-align: center;
		z-index: 3;
	}

	.name {
		font-size: 60px;
		margin-bottom: 20px;
		font-weight: 700;
		letter-spacing: 10px;
		text-transform: uppercase;
		font-family: 'Open Sans', sans-serif;
	}

	.main-header.light .name {
		color: #000000;
	}

	.main-header.dark .name {
		color: #ffffff;
	}

	.job {
		position: relative;
		display: inline-block;
		padding: 10px;
		letter-spacing: 4px;
		text-transform: uppercase;
		font-family: Georgia, serif;
		font-size: 1.5em;
	}

	.main-header.light .job {
		color: #000000;
		border-bottom: 1px solid #000000;
	}

	.main-header.dark .job {
		color: #ffffff;
		border-bottom: 1px solid #ffffff;
	}

	.typed-text::after {
		content: "|";
		margin-left: 3px;
		animation: blink-cursor 0.8s step-end infinite;
	}

	@keyframes blink-cursor {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0;
		}
	}

	@media (max-width: 1030px) {
		.name {
			font-size: 3em;
		}
	}

	@media (max-width: 600px) {
		.name {
			font-size: 2em;
			letter-spacing: 5px;
		}
	}
</style>

<script>
	const TYPE_SPEED = 180;
	const DELETE_SPEED = 100;
	const PAUSE_AFTER_TYPE = 2000;
	const PAUSE_AFTER_DELETE = 600;

	function typeLoop(el: HTMLElement) {
		const text = el.textContent?.trim() ?? '';
		let i = 0;
		let deleting = false;
		el.textContent = '';

		const tick = () => {
			if (!deleting) {
				i++;
				el.textContent = text.slice(0, i);
				if (i === text.length) {
					deleting = true;
					setTimeout(tick, PAUSE_AFTER_TYPE);
					return;
				}
				setTimeout(tick, TYPE_SPEED);
			} else {
				i--;
				el.textContent = text.slice(0, i);
				if (i === 0) {
					deleting = false;
					setTimeout(tick, PAUSE_AFTER_DELETE);
					return;
				}
				setTimeout(tick, DELETE_SPEED);
			}
		};

		tick();
	}

	document.querySelectorAll<HTMLElement>('.typed-text').forEach(typeLoop);
</script>
