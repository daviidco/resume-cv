---
interface Props {
	theme?: 'light' | 'dark';
}

const { theme = 'light' } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class={`main-footer ${theme}`}>
	<div class="container-medium">
		<div class="folow-me">Follow Me On</div>
		<ul class="social-links">
			<li><a href="#" title="Facebook"><i class="fa fa-facebook"></i></a></li>
			<li><a href="#" title="Google"><i class="fa fa-google"></i></a></li>
			<li><a href="#" title="Twitter"><i class="fa fa-twitter"></i></a></li>
			<li><a href="#" title="Linkedin"><i class="fa fa-linkedin"></i></a></li>
			<li><a href="#" title="Github"><i class="fa fa-github"></i></a></li>
		</ul>
		<p class="copyright">Paulo Cordoba - All Rights Reserved &copy; {currentYear}</p>
		<a href="#home" class="back-to-top" aria-label="Back to top"><i class="fa fa-angle-double-up"></i></a>
	</div>
</footer>

<style>
	.main-footer {
		position: relative;
		padding-bottom: 40px;
		padding-top: 40px;
		font-size: 12px;
		text-align: center;
		overflow: hidden;
	}

	.main-footer.light {
		background: #323232;
		border-top: 1px solid #505050;
		border-bottom: 5px solid #505050;
		color: #7d7d7d;
	}

	.main-footer.dark {
		background: #1e1e1e;
		border-top: 1px solid #000000;
		border-bottom: 5px solid #000000;
		color: #7d7d7d;
	}

	.main-footer:before {
		content: '';
		position: absolute;
		width: 50%;
		right: 0;
		bottom: 0;
		height: 100%;
	}

	.main-footer.light:before {
		background: rgba(0, 0, 0, 0.05);
	}

	.main-footer.dark:before {
		background: rgba(0, 0, 0, 0.1);
	}

	.container-medium {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 15px;
		position: relative;
	}

	.folow-me {
		text-align: center;
		padding: 5px;
		margin: 0 auto 20px;
		width: 150px;
		color: #ffffff;
	}

	.main-footer.light .folow-me {
		background: #505050;
	}

	.main-footer.dark .folow-me {
		background: #141414;
	}

	.social-links {
		list-style: none;
		display: flex;
		justify-content: center;
		gap: 0;
		margin: 0 0 10px;
		padding: 0;
	}

	.social-links a {
		position: relative;
		color: #ffffff;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.8s ease;
		width: 30px;
		height: 30px;
		font-size: 16px;
		text-decoration: none;
		background: #282828;
	}

	.social-links a:hover {
		background: #ffffff;
		color: #000000;
	}

	.copyright {
		margin: 0;
		position: relative;
	}

	.back-to-top {
		position: absolute;
		bottom: -5px;
		left: 50%;
		display: block;
		width: 30px;
		height: 30px;
		margin-left: -15px;
		text-decoration: none;
		line-height: 30px;
		text-align: center;
		color: #7d7d7d;
	}

	.main-footer.light .back-to-top {
		background: #505050;
	}

	.main-footer.dark .back-to-top {
		background: #141414;
	}

	.back-to-top:hover {
		color: #ffffff;
	}
</style>
