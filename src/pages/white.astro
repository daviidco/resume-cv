---
import Hero from '../components/Hero.astro';
import Nav from '../components/Nav.astro';
import About from '../components/About.astro';
import Resume from '../components/Resume.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Paulo Cordoba - Software Engineer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link href="https://fonts.googleapis.com/css?family=Open+Sans:400,400italic,700,800" rel="stylesheet" />
		<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet" />
	</head>
	<body>
		<Hero name="I'm Paulo Cordoba" job="A Software Engineer" theme="light">
			<Nav slot="nav" theme="light" />
		</Hero>

		<About theme="light" />

		<Resume theme="light" />

		<!--
		Hidden until implemented:
		<section id="portfolio" class="placeholder-section">
			<h2>Portfolio</h2>
			<p>Content coming soon.</p>
		</section>
		<section id="blog" class="placeholder-section alt">
			<h2>Blog</h2>
			<p>Content coming soon.</p>
		</section>
		-->
		<Contact theme="light" />

		<Footer theme="light" />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		background: #ffffff;
		color: #7d7d7d;
		font-family: 'Open Sans', sans-serif;
		line-height: 2;
		font-size: 13px;
		-webkit-font-smoothing: antialiased;
	}

	h1, h2, h3, h4, h5, h6 {
		line-height: 1.2;
		font-family: 'Open Sans', sans-serif;
		font-weight: 500;
	}
	h1 { letter-spacing: 3px; font-size: 4em; }
	h2 { letter-spacing: 2.5px; font-size: 3em; }
	h3 { letter-spacing: 2px; font-size: 2em; }
	h4 { font-size: 1.5em; }
	h5 { font-size: 1.2em; }
	h6 { font-size: 1em; }
	h4, h5, h6 { letter-spacing: 1px; }

	.placeholder-section {
		position: relative;
		z-index: 1;
		min-height: 60vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		background: #ffffff;
		color: #000000;
	}

	.placeholder-section.alt {
		background: #f5f5f5;
	}

	.placeholder-section h2 {
		text-transform: uppercase;
		letter-spacing: 2.5px;
		font-weight: 700;
	}
</style>
